      "name": "Sticky Note"
    },
    {
      "parameters": {
        "jsCode": "const leadData = $('🧹 Clean Lead Data').item.json;\nconst aiResponse = $json.message.content;\n\n// Parse the JSON response from OpenAI\nlet aiData;\ntry {\n  aiData = JSON.parse(aiResponse);\n} catch (error) {\n  // If parsing fails, try to extract JSON from markdown code blocks\n  const jsonMatch = aiResponse.match(/```(?:json)?\\s*([\\s\\S]*?)```/);\n  if (jsonMatch) {\n    aiData = JSON.parse(jsonMatch[1]);\n  } else {\n    throw new Error('Failed to parse AI response as JSON');\n  }\n}\n\n// Merge lead data with AI analysis\nreturn [{\n  json: {\n    ...leadData,\n    ...aiData\n  }\n}];"
      },
      "id": "5bae68b8-107f-4014-94b3-96d630464ced",
      "name": "🧩 Parse AI Lead Data",
