        "responses": {
          "values": [
            {
              "content": "=You are a lead qualification expert. Analyze the following lead information and return ONLY valid JSON with no additional text.\n\nLead Information:\n- Name: {{ $json.name }}\n- Email: {{ $json.email }}\n- Company: {{ $json.company }}\n- Website: {{ $json.website }}\n- Need: {{ $json.need }}\n- Company Info: {{ $('🌐 Fetch Company Info').item.json }}\n\nReturn JSON in this exact format:\n{\n  \"company_summary\": \"brief summary of the company\",\n  \"industry\": \"industry name\",\n  \"pain_points\": [\"pain point 1\", \"pain point 2\"],\n  \"lead_score\": 75,\n  \"lead_temperature\": \"hot\",\n  \"recommended_offer\": \"specific automation service\",\n  \"personalized_outreach\": \"professional outreach message\"\n}\n\nRules:\n- lead_score: 0-100\n- lead_temperature: must be \"hot\", \"warm\", or \"cold\"\n- Return ONLY the JSON object, no markdown, no explanation"
            }
          ]
        },
        "builtInTools": {},
        "options": {
          "temperature": 0.2
        }
      },
